{
  "name": "api-explorer",
  "displayName": "API Explorer",
  "description": "Zero-config API explorer for FastAPI and OpenAPI projects. Auto-discovers endpoints, fires requests, and navigates to source - without leaving VSCode.",
  "version": "0.1.1",
  "private": false,
  "publisher": "sahilrajpal",
  "author": "Sahil Rajpal",
  "preview": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahilr05/vscode-api-explorer"
  },
  "bugs": {
    "url": "https://github.com/sahilr05/vscode-api-explorer/issues"
  },
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Testing",
    "Visualization"
  ],
  "keywords": [
    "api",
    "rest",
    "fastapi",
    "openapi",
    "swagger",
    "http",
    "client",
    "explorer",
    "testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "API Explorer",
      "properties": {
        "apiExplorer.openapiUrl": {
          "type": "string",
          "default": "http://localhost:8000/openapi.json",
          "description": "URL of the OpenAPI specification"
        }
      }
    },
    "commands": [
      {
        "command": "apiExplorer.filterByModule",
        "title": "Filter by Module",
        "icon": "$(folder-library)"
      },
      {
        "command": "apiExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "apiExplorer.changeBaseUrl",
        "title": "API Explorer: Change Base URL"
      },
      {
        "command": "apiExplorer.search",
        "title": "Search Endpoints",
        "icon": "$(search)"
      },
      {
        "command": "apiExplorer.clearSearch",
        "title": "Clear Search",
        "icon": "$(search-stop)"
      },
      {
        "command": "apiExplorer.groupByMethod",
        "title": "Group by Method",
        "icon": "$(list-unordered)"
      },
      {
        "command": "apiExplorer.groupByModule",
        "title": "Group by Module",
        "icon": "$(folder)"
      },
      {
        "command": "apiExplorer.filterByMethod",
        "title": "Filter by Method",
        "icon": "$(filter)"
      },
      {
        "command": "apiExplorer.toggleSort",
        "title": "Toggle Sort Order",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "apiExplorer.clearHistory",
        "title": "Clear History",
        "icon": "$(trash)"
      },
      {
        "command": "apiExplorer.goToSource",
        "title": "Go to Source",
        "icon": "$(code)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "api-explorer",
          "title": "API Explorer",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "api-explorer": [
        {
          "id": "apiExplorer.endpoints",
          "name": "Endpoints"
        },
        {
          "id": "apiExplorer.history",
          "name": "History"
        }
      ]
    },
    "menus": {
      "view/item/inline": [
        {
          "command": "apiExplorer.goToSource",
          "when": "view == apiExplorer.endpoints && viewItem == endpointWithSource",
          "group": "inline"
        }
      ],
      "view/item/context": [
        {
          "command": "apiExplorer.goToSource",
          "when": "view == apiExplorer.endpoints && viewItem == endpointWithSource",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "apiExplorer.search",
          "when": "view == apiExplorer.endpoints && !apiExplorer.searchActive",
          "group": "navigation@1"
        },
        {
          "command": "apiExplorer.clearSearch",
          "when": "view == apiExplorer.endpoints && apiExplorer.searchActive",
          "group": "navigation@1"
        },
        {
          "command": "apiExplorer.groupByMethod",
          "when": "view == apiExplorer.endpoints && apiExplorer.groupMode != 'method'",
          "group": "navigation@2"
        },
        {
          "command": "apiExplorer.groupByModule",
          "when": "view == apiExplorer.endpoints && apiExplorer.groupMode != 'module'",
          "group": "navigation@3"
        },
        {
          "command": "apiExplorer.filterByModule",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@4"
        },
        {
          "command": "apiExplorer.filterByMethod",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@5"
        },
        {
          "command": "apiExplorer.toggleSort",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@6"
        },
        {
          "command": "apiExplorer.refresh",
          "when": "view == apiExplorer.endpoints",
          "group": "navigation@7"
        },
        {
          "command": "apiExplorer.clearHistory",
          "when": "view == apiExplorer.history",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "clean": "rm -rf out",
    "lint": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.85.0",
    "typescript": "~5.8.2"
  }
}